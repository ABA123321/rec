# ─── Chain Integration ──────────────────────────────────────────
# Frontend reads these at build time (Next.js inlines NEXT_PUBLIC_*).
# Copy this file to .env.local for local dev or set them in Vercel.

# 链 ID — BSC mainnet 56 / testnet 97
NEXT_PUBLIC_CHAIN_ID=56

# RPC URL（推荐 publicnode 或自有 RPC）
NEXT_PUBLIC_RPC_URL=https://bsc.publicnode.com

# 部署起始区块 — eth_getLogs 扫描下界
NEXT_PUBLIC_DEPLOY_BLOCK=106289982

# ─── Contract Addresses (BSC mainnet · V48 正式部署) ────
