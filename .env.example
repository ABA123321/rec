# ─── Chain Integration ──────────────────────────────────────────
# Frontend reads these at build time (Next.js inlines NEXT_PUBLIC_*).
# Copy this file to .env.local for local dev or set them in Vercel.

# 链 ID — BSC mainnet 56 / testnet 97
NEXT_PUBLIC_CHAIN_ID=56

# 单一 RPC URL — 推荐自有 RPC（QuickNode / Ankr / GetBlock）；
# fallback 是 https://bsc-dataseed.binance.org（公共，限流）
NEXT_PUBLIC_RPC_URL=https://bsc.nodereal.io

# 部署起始区块 — 用于 eth_getLogs 下界，避免免费 RPC 全链扫描
NEXT_PUBLIC_DEPLOY_BLOCK=95849570

# ─── Contract Addresses (BSC mainnet · 与代码内 fallback 一致) ────
NEXT_PUBLIC_REFERRAL_REGISTRY_ADDRESS=0x9DC2C0fab8D0312c0ffb6d5275b0db48a11557df
NEXT_PUBLIC_STAMINA_ADDRESS=0xEdDe1C8Be5a22042904411aC42D2a3914Bd4E2F6
NEXT_PUBLIC_ADVENT_ADDRESS=0x5E7E9E65FC1C8A92af104100B35B2ABF7C41A1c4
NEXT_PUBLIC_MATERIALS_ADDRESS=0xa398AE7E9546feDa47Cef042cFfeA5a173AAaeB8
NEXT_PUBLIC_CHARACTER_NFT_ADDRESS=0x2D81F99Dd0a4c72f5b3DbB3C556f601a00F666f8
NEXT_PUBLIC_GAME_ADDRESS=0xf34C786BdEF2839282b25aaB9f1207114203AD6b
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x4e0134b26Ab08C21641CE1073c19Bc53c0f8C011
NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# ─── Server-only（/api/chat · 符文妹妹）───────────────────────────
# 不在浏览器暴露；部署到 Vercel 时在项目 Environment Variables 里配置。
# GROQ_API_KEY=gsk_xxxxxxxx
